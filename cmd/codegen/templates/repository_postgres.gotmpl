		return nil, xerr.BadRequest("更新字段不能为空")
	}
	result := r.db.WithContext(ctx).
		Model(&models.{{.Model}}{}).
{{.UpdateFieldsScope}}
		Select(columns).
		Updates({{.ModelVar}})
	if result.Error != nil {
		return nil, xerr.Wrapf(result.Error, "更新{{.Label}}失败")
	}
	if result.RowsAffected == 0 {
		return nil, xerr.NotFound("{{.Label}}不存在")
	}
	return r.FindByID(ctx, userID, {{.ModelVar}}ID)
}

func (r *{{.Model}}Repository) Delete(ctx context.Context, userID uuid.UUID, {{.ModelVar}}ID uuid.UUID) error {
	result := r.db.WithContext(ctx).
{{.DeleteScope}}
		Delete(&models.{{.Model}}{})
	if result.Error != nil {
