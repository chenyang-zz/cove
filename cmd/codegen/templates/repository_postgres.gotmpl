func (r *{{.Model}}Repository) FindByID(ctx context.Context, userID uuid.UUID, {{.ModelVar}}ID uuid.UUID) (*models.{{.Model}}, error) {
	{{.ModelVar}} := &models.{{.Model}}{}
	err := r.db.WithContext(ctx).{{.FindScope}}
		First({{.ModelVar}}).Error
	if errors.Is(err, gorm.ErrRecordNotFound) {
		return nil, xerr.NotFound("{{.Label}}不存在")
	}
	if err != nil {
		return nil, xerr.Wrapf(err, "查询{{.Label}}失败")
	}
	return {{.ModelVar}}, nil
}

func (r *{{.Model}}Repository) Update(ctx context.Context, userID uuid.UUID, {{.ModelVar}} *models.{{.Model}}) (*models.{{.Model}}, error) {
	result := r.db.WithContext(ctx).
		Model(&models.{{.Model}}{}).
{{.UpdateScope}}
		Omit("id", "user_id", "user", "created_at", "updated_at").
		Updates({{.ModelVar}})
	if result.Error != nil {
		return nil, xerr.Wrapf(result.Error, "更新{{.Label}}失败")
	}
	if result.RowsAffected == 0 {
		return nil, xerr.NotFound("{{.Label}}不存在")
	}
	return r.FindByID(ctx, userID, {{.ModelVar}}.ID)
}

func (r *{{.Model}}Repository) UpdateFields(ctx context.Context, userID uuid.UUID, {{.ModelVar}}ID uuid.UUID, {{.ModelVar}} *models.{{.Model}}, fields *repository.{{.Model}}UpdateFields) (*models.{{.Model}}, error) {
	columns := fields.Columns()
